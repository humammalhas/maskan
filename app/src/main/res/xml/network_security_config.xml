<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!--
         Cloud API providers: cleartext (HTTP) is forbidden.
         includeSubdomains="true" so that any future sub-path or
         regional subdomain is also forced over HTTPS.
         Base-config keeps cleartext permitted so that local providers
         (Ollama, LM Studio) reachable on localhost / LAN IPs work over HTTP.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.deepseek.com</domain>
        <domain includeSubdomains="true">api.openai.com</domain>
        <domain includeSubdomains="true">api.groq.com</domain>
        <domain includeSubdomains="true">api.together.xyz</domain>
        <domain includeSubdomains="true">api.mistral.ai</domain>
        <domain includeSubdomains="true">openrouter.ai</domain>
        <domain includeSubdomains="true">api.anthropic.com</domain>
        <domain includeSubdomains="true">generativelanguage.googleapis.com</domain>
    </domain-config>
</network-security-config>
